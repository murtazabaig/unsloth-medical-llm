        "size": "~60k clinical notes",
        "description": "De-identified clinical data (requires registration)"
      }
    ],
    "data_preparation_steps": [
      "1. Collect or download medical Q&A data",
      "2. Clean and validate data (remove duplicates, encode issues)",
      "3. Format according to instruction template",
      "4. Split into train/eval sets",
      "5. Validate domain relevance and data quality",
      "6. Save in CSV or JSONL format"
